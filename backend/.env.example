# Copy to .env and fill in.
#
# --- Local dev (recommended): use gcloud, no key file ---
# 1. Run:  gcloud auth application-default login
# 2. Start the backend from that SAME terminal so it sees your credentials:
#    cd backend && ../.venv/bin/uvicorn main:app --reload --host 0.0.0.0 --port 8080
# Leave GOOGLE_APPLICATION_CREDENTIALS unset (or commented out).
#
# --- Alternative: service account key file ---
# When you have a key file, set GOOGLE_APPLICATION_CREDENTIALS to its absolute path.

GOOGLE_CLOUD_PROJECT=project-8be520bb-b4ac-4d57-a37
# GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/MedMate/backend/service-account.json

# Optional: SMTP for notifying emergency contact when a dose is not taken (e.g. Gmail SMTP)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASSWORD=your-app-password
# FROM_EMAIL=medmate@yourdomain.com
